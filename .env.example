# ─── Base de Datos ────────────────────────────────────────────────
DATABASE_URL="postgresql://impacta:impacta_dev_pass@localhost:5433/impacta_dev"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET="impacta_saas_dev_secret_key_32_chars_min"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
WEB_URL="http://localhost:5173"
LANDING_URL="http://localhost:3001"
ADMIN_URL="http://localhost:5174"
VITE_API_URL="http://localhost:4000/api"
PORT=4000

# ─── Storage ──────────────────────────────────────────────────────
STORAGE_PROVIDER="local"
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ROOT_USER="impacta"
MINIO_ROOT_PASSWORD="impacta_dev_pass"
MINIO_BUCKET="impacta"

# ─── Super Admin (seed) ───────────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@impacta.cl"
SUPER_ADMIN_PASSWORD="your_secure_password_here"

